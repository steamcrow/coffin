{
  "schema_id": "cc_terrain_catalog",
  "schema_version": "2.0",
  "last_updated": "2026-03-21",
  "notes": [
    "Catalog entries define reusable terrain assets for the Leaflet map editor, Turn Counter integration, and future solo simulation.",
    "This file defines WHAT each image is. Per-map placement should live in terrain_instances.json later.",
    "Some names are intentionally generic in the first batch where the art is clear in function but not specific enough yet for exact named building identity.",
    "location_tags are the bridge to 150_location_types.json later."
  ],
  "enums": {
    "terrain_kind": ["building", "scatter", "obstacle", "area", "hazard", "feature", "objective"],
    "footprint_shape": ["rect", "circle", "poly", "line"],
    "los_profile": ["blocks", "partial", "none"],
    "cover_grade": ["none", "light", "heavy"],
    "climb_mode": ["none", "ladder", "stairs", "scramble", "rope", "any"],
    "surface_kind": ["ground", "interior", "balcony", "roof", "catwalk", "platform", "stairs"],
    "slot_kind": ["objective", "spawn", "loot", "interaction", "hazard_anchor", "story_anchor"]
  },
