{
  "_id": "R-MOVE",
  "title": "Locomotion Vault",
  "philosophy": {
    "_id": "R-MOVE-00",
    "title": "Philosophy",
    "short": "Movement decides fights. Standing still is dangerous.",
    "long": "Movement decides fights. Where you stand matters more than how hard you hit. Standing still should feel dangerous.",
    "notes": "Movement should be fluid; terrain should force choices. If a model survives long enough, it was probably moving."
  },
  "movement_basics": {
    "_id": "R-MOVE-01",
    "title": "Movement Basics",
    "short": "Move in inches from base; up to Move per action.",
    "long": "",
    "value_usage": "Measure in inches from the model's base. Up to full Move value per action.",
    "flexibility": "Movement may be split by other actions unless explicitly forbidden (e.g., Move-Attack-Move)."
  },
  "terrain_penalties": {
    "_id": "R-MOVE-02",
    "title": "Terrain Penalties",
    "short": "",
    "long": "",
    "open": "No effect. Free movement.",
    "difficult": {
      "_id": "R-MOVE-02A",
      "title": "Difficult",
      "short": "Movement is halved (round down)",
      "long": "Movement is halved (round down). Does not stack with other move penalties.",
      "examples": [
        "Rubble",
        "Steep slopes",
        "Deep mud",
        "Thick debris"
      ]
    },
    "impassable": {
      "_id": "R-MOVE-02B",
      "title": "Impassable",
      "short": "Cannot enter, pass through, or end movement inside",
      "long": "Cannot enter, pass through, or end movement inside. Blocks LoS if solid.",
      "examples": [
        "Solid cliff faces",
        "Intact walls",
        "Deep chasms",
        "Sealed structures"
      ]
    }
  },
  "model_interaction": {
    "_id": "R-MOVE-03",
    "title": "Model Interaction",
    "short": "",
    "long": "",
    "enemy_models": "May not move through.",
    "friendly_models": "May move through if space allows and bases do not overlap at the end."
  },
  "engagement_and_pressure": {
    "_id": "R-MOVE-04",
    "title": "Engagement And Pressure",
    "short": "Engaged when within melee range of an enemy model",
    "long": "Engaged when within melee range of an enemy model.",
    "lock_in": "No universal lock-in; engaged models may move freely unless an ability says otherwise.",
    "melee_pressure_penalty": {
      "_id": "R-MOVE-04A",
      "condition": "While engaged with 1+ enemies",
      "effects": [
        "-1 die on Ranged attacks",
        "Cannot gain Cover from terrain"
      ],
      "restriction": "Does not apply to melee attacks."
    }
  },
  "verticality": {
    "_id": "R-MOVE-05",
    "title": "Verticality",
    "short": "",
    "long": "",
    "climbing": "Measure vertical distance normally. Terrain may be impassable vertically or require specific actions.",
    "risk": "Unstable terrain may cause falls."
  },
  "trait_priority": {
    "_id": "R-MOVE-06",
    "title": "Trait Priority",
    "short": "Resolve movement first, then resolve terrain effects",
    "long": "Resolve movement first, then resolve terrain effects.",
    "interactions": [
      {
        "trait": "Hazardous",
        "trigger": "Quality test when entering/passing through"
      },
      {
        "trait": "Unstable",
        "trigger": "Risk when ending movement"
      },
      {
        "trait": "Choking",
        "trigger": "Fog condition while activating"
      },
      {
        "trait": "Burning",
        "trigger": "Automatic damage"
      }
    ]
  }
}
