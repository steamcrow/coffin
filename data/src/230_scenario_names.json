  "matching_rules": {
    "desc_long": "How to match prefixes and suffixes to scenario content",
    "priority": [
      "Check for thyr/crystal objectives → use thyr-tagged prefixes",
      "Check for death/grave themes → use death-tagged prefixes",
      "Check for monster faction/content → use monster-tagged prefixes",
      "Check for outlaw/combat themes → use combat-tagged prefixes",
      "Check danger rating → use danger_X-tagged prefixes",
      "Check for mystical/ritual → use mystical-tagged prefixes",
      "Check location type → use location-tagged prefixes",
      "Fallback to time-based or general prefixes"
    ],
    "suffix_matching": [
      "If location name is short/dramatic → use location name directly",
      "Otherwise match objective types to objective_X tags",
      "Match plot family to plot_X tags",
      "Match twist type to twist_X tags",
      "Fallback to generic tags"
    ]
  },
